<%- include('../partials/header') %>
<%- include('../partials/navbar', { user: user }) %>

<div class="container">
  <div class="page-header">
    <h1>All Reservations</h1>
  </div>

  <div class="filters">
    <form method="GET" action="/admin/reservations" class="filter-form">
      <input type="date" name="date" value="<%= filters.date || '' %>" placeholder="Filter by date">
      <select name="status">
        <option value="">All Statuses</option>
        <option value="BOOKED" <%= filters.status === 'BOOKED' ? 'selected' : '' %>>Booked</option>
        <option value="CANCELLED" <%= filters.status === 'CANCELLED' ? 'selected' : '' %>>Cancelled</option>
      </select>
      <button type="submit" class="btn btn-primary">Filter</button>
      <a href="/admin/reservations" class="btn btn-secondary">Clear</a>
    </form>
  </div>

  <% if (reservations && reservations.length > 0) { %>
    <div class="table-responsive">
      <table class="data-table">
        <thead>
          <tr>
            <th>User</th>
            <th>Email</th>
            <th>Table</th>
            <th>Date</th>
            <th>Time</th>
            <th>Guests</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% reservations.forEach(reservation => { %>
            <tr>
              <td><%= reservation.userId.name %></td>
              <td><%= reservation.userId.email %></td>
              <td>Table <%= reservation.tableId.tableNumber %></td>
              <td><%= new Date(reservation.date).toLocaleDateString() %></td>
              <td><%= reservation.startTime %> - <%= reservation.endTime %></td>
              <td><%= reservation.guestCount %></td>
              <td>
                <span class="badge badge-<%= reservation.status.toLowerCase() %>">
                  <%= reservation.status %>
                </span>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <div class="pagination">
      <% if (currentPage > 1) { %>
        <a href="?page=<%= currentPage - 1 %><%= filters.date ? '&date=' + filters.date : '' %><%= filters.status ? '&status=' + filters.status : '' %>" 
           class="btn btn-secondary">Previous</a>
      <% } %>
      <span>Page <%= currentPage %> of <%= totalPages %></span>
      <% if (currentPage < totalPages) { %>
        <a href="?page=<%= currentPage + 1 %><%= filters.date ? '&date=' + filters.date : '' %><%= filters.status ? '&status=' + filters.status : '' %>" 
           class="btn btn-secondary">Next</a>
      <% } %>
    </div>
  <% } else { %>
    <p class="no-data">No reservations found.</p>
  <% } %>
</div>

<%- include('../partials/footer') %>
