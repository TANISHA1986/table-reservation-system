<%- include('../partials/header') %>
<%- include('../partials/navbar', { user: user }) %>

<div class="container">
  <div class="page-header">
    <h1>Manage Tables</h1>
  </div>

  <div class="section">
    <h2>Add New Table</h2>
    <form id="addTableForm" class="inline-form">
      <input type="text" id="tableNumber" placeholder="Table Number" required>
      <input type="number" id="capacity" placeholder="Capacity" min="1" max="20" required>
      <button type="submit" class="btn btn-primary">Add Table</button>
    </form>
  </div>

  <div class="section">
    <h2>Existing Tables</h2>
    <% if (tables && tables.length > 0) { %>
      <div class="table-responsive">
        <table class="data-table">
          <thead>
            <tr>
              <th>Table Number</th>
              <th>Capacity</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% tables.forEach(table => { %>
              <tr>
                <td>Table <%= table.tableNumber %></td>
                <td><%= table.capacity %> people</td>
                <td>
                  <% if (table.isActive) { %>
                    <span class="badge badge-success">Active</span>
                  <% } else { %>
                    <span class="badge badge-danger">Inactive</span>
                  <% } %>
                </td>
                <td>
                  <% if (table.isActive) { %>
                    <button onclick="toggleTableStatus('<%= table._id %>', false)" class="btn btn-sm btn-warning">
                      Deactivate
                    </button>
                  <% } else { %>
                    <button onclick="toggleTableStatus('<%= table._id %>', true)" class="btn btn-sm btn-success">
                      Activate
                    </button>
                  <% } %>
                  <button onclick="deleteTable('<%= table._id %>')" class="btn btn-sm btn-danger">
                    Delete
                  </button>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="no-data">No tables found. Add your first table above.</p>
    <% } %>
  </div>
</div>

<script>
document.getElementById('addTableForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  
  const formData = {
    tableNumber: document.getElementById('tableNumber').value,
    capacity: parseInt(document.getElementById('capacity').value)
  };

  try {
    const response = await fetch('/api/admin/tables', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + localStorage.getItem('token')
      },
      body: JSON.stringify(formData)
    });

    const data = await response.json();

    if (data.success) {
      alert('Table added successfully!');
      location.reload();
    } else {
      alert(data.message || 'Failed to add table');
    }
  } catch (error) {
    alert('Error: ' + error.message);
  }
});

function toggleTableStatus(id, isActive) {
  fetch('/api/admin/tables/' + id + '/status', {
    method: 'PATCH',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + localStorage.getItem('token')
    },
    body: JSON.stringify({ isActive: isActive })
  })
  .then(response => response.json())
  .then(data => {
    if (data.success) {
      alert('Table status updated successfully!');
      location.reload();
    } else {
      alert(data.message || 'Failed to update status');
    }
  })
  .catch(error => {
    alert('Error: ' + error.message);
  });
}

function deleteTable(id) {
  if (!confirm('Are you sure you want to delete this table?')) return;

  fetch('/api/admin/tables/' + id, {
    method: 'DELETE',
    headers: {
      'Authorization': 'Bearer ' + localStorage.getItem('token')
    }
  })
  .then(response => response.json())
  .then(data => {
    if (data.success) {
      alert('Table deleted successfully!');
      location.reload();
    } else {
      alert(data.message || 'Failed to delete table');
    }
  })
  .catch(error => {
    alert('Error: ' + error.message);
  });
}
</script>

<%- include('../partials/footer') %>
